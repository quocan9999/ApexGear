# ─────────────────────────────────────────────────────────────
# ApexGear API — environment variables
# Copy this file to .env (same folder) and fill in real values.
# Only the API consumes these (web/admin use a hardcoded Vite proxy).
# ─────────────────────────────────────────────────────────────

# ── Database (REQUIRED) ──
# SQL Server connection string. trustServerCertificate=true for local dev.
DATABASE_URL="sqlserver://localhost:1433;database=apexgear;user=sa;password=YourPassword;encrypt=true;trustServerCertificate=true"

# ── JWT (REQUIRED) ──
# Change JWT_SECRET in production. JWT_EXPIRES_IN sets access-token TTL.
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# ── CORS origins ──
FRONTEND_URL="http://localhost:5173"
ADMIN_URL="http://localhost:5174"

# ── Cloudinary (image uploads) ──
# Optional for non-upload flows; required to use the upload feature.
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ── Google OAuth ──
# Optional. Required only if Google sign-in is enabled.
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"

# ── Email / Gmail SMTP (password reset) ──
# Optional. Required only for the forgot/reset password flow.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="ApexGear <noreply@apexgear.vn>"

# ── SePay (bank-transfer payments) ──
# Optional in local mock. SEPAY_WEBHOOK_SECRET verifies the webhook HMAC.
SEPAY_WEBHOOK_SECRET="your-webhook-hmac-secret"
SEPAY_BANK_ACCOUNT="your-bank-account-number"

# ── Runtime ──
NODE_ENV="development"
PORT="3001"
