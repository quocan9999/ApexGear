{
  "name": "apexgear",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "postinstall": "prisma generate --schema=apps/api/prisma/schema.prisma",
    "dev:api": "npm run dev -w apps/api",
    "build:api": "npm run build -w apps/api",
    "lint:api": "npm run lint -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "test:web": "npm run test -w apps/web",
    "dev:admin": "npm run dev --workspace=admin",
    "build:admin": "npm run build --workspace=admin",
    "lint:admin": "npm run lint --workspace=admin",
    "test:admin": "npm run test --workspace=admin"
  }
}
